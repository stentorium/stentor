{
  "packages": ["packages/**", "website"],
  "npmClient": "yarn",
  "version": "1.55.6",
  "useWorkspaces": true,
  "command": {
    "init": {
      "exact": true
    },
    "version": {
      "allowBranch": ["master"],
      "exact": true,
      "conventionalCommits": true,
      "message": "chore(release): 📣⚡ publish release %v [skip ci]"
    },
    "publish": {
      "conventionalCommits": true
    }
  }
}
