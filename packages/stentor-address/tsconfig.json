{
  "extends": "@xapp/config/tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "esModuleInterop": true,
    "types": ["node", "mocha"],
    "strictNullChecks": false
  },
  "include": ["src", "typings/**/*.d.ts"],
  "exclude": ["node_modules", "src/**/__test__/*"],
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}
