{
  "extends": "@xapp/config/tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "strict": true,
    "strictNullChecks": false,
    "lib": ["es2017", "dom"],
    "types": ["node", "mocha"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/**/__test__/*", "src/**/__tests__/*"],
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}
