{
  "extends": "@xapp/config/tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "lib": ["es2016", "dom"],
    "types": ["node", "mocha"]
  },
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs"
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/**/__test__/*"]
}
