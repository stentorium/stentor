{
  "extends": "@xapp/config/tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "strictNullChecks": false,
    "types": ["node", "mocha"],
    "esModuleInterop": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/**/__test__/*"],
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs",
      "esModuleInterop": true
    }
  }
}
