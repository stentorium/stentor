{
  "extends": "@xapp/config/tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "skipLibCheck": true,
    "types": ["node", "mocha"]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "src/**/__test__/*"
  ],
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}